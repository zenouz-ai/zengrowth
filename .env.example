# ZenGrowth environment template — copy to .env and fill in.
# Every value below is a placeholder. Never commit a real .env.

# --- API keys ---
# ANTHROPIC: required for scoring, summaries, materials, knowledge extraction.
# TAVILY: required only for the "Find jobs" discovery search (optional feature).
# OPENAI: optional — only needed if KNOWLEDGE_EMBEDDINGS_ENABLED=true (off by default;
#   the chunk vectors are not read by any retrieval path yet — see docs/SCORING_AND_EXPECTED_VALUE.md).
ANTHROPIC_API_KEY=sk-ant-replace-me
TAVILY_API_KEY=tvly-replace-me
# OPENAI_API_KEY=sk-proj-replace-me

# --- Models ---
SCORING_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# --- Database ---
DATABASE_URL=sqlite:///data/zengrowth.db

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443

# --- Candidate identity (printed on generated materials) ---
# Placeholders only — set your own locally. Never commit real personal data.
USER_FULL_NAME=Jordan Avery
USER_EMAIL=jordan.avery@example.com
USER_PHONE=
USER_LINKEDIN=
MATERIALS_EXPORT_NAME=Jordan_Avery
USER_LOCATION=Remote

# --- Target profile (steers the scoring prompt) ---
# Replace with the roles/sectors/compensation you are actually targeting.
USER_TARGET_ROLES=Head of AI,Director of Data Science,Lead AI Engineer
USER_TARGET_SECTORS=AI,FinTech,Healthcare,Research
USER_HYBRID_MAX_OFFICE_DAYS=3
USER_COMP_MIN_GBP=0
USER_COMP_TARGET_GBP=0

# --- Ingestion ---
# Comma-separated entries of the form `provider:slug` — see docs/ATS_INGESTION.md.
# These are public, well-known example boards; swap for the boards you track.
ATS_BOARDS=greenhouse:example,lever:example
# Drop postings older than this; set to 0 to disable.
MAX_POSTING_AGE_DAYS=14
# Run a bounded clean/score/archive pass after ATS ingestion so the pipeline
# shows only curated jobs. Set to false if you want raw discovery rows only.
INGESTION_PRECHECK_ON_RUN=true
INGESTION_PRECHECK_BATCH_LIMIT=50
# Minimum fit score for auto-ingested jobs on the curated board. Manual jobs bypass this.
PIPELINE_MIN_FIT_SCORE=55

# --- Scheduler ---
# Cron-ish hour at which the nightly ATS pull runs (0-23 local).
INGESTION_HOUR=6

# --- Failure detection / cost / login hardening ---
# Dead-man's-switch heartbeat pinged after each successful ingest (unset = off).
# INGEST_HEARTBEAT_URL=https://hc-ping.example/your-uuid
# INGESTION_STALE_AFTER_HOURS=26
# Soft daily LLM spend ceiling in USD; calls 503 past it. 0 = disabled.
# LLM_DAILY_BUDGET_USD=0
# App-level login backoff behind the edge limiter. 0 = disabled.
# LOGIN_MAX_ATTEMPTS=10
# LOGIN_LOCKOUT_SECONDS=300

# --- Operator auth & edge hardening ---
# Single-operator login. Generate the hash with:
#   python -m zengrowth.api.security hash 'your-password'
# In dev (REQUIRE_HTTPS unset/false) the auth gate falls back to a localhost
# bypass so you can run without configuring these. Production MUST set
# ZENGROWTH_REQUIRE_HTTPS=true, which makes the app refuse to boot unless both
# the password hash and session secret are present.
ZENGROWTH_OPERATOR_PASSWORD_HASH=
# Random secret for signing session cookies, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
ZENGROWTH_SESSION_SECRET=
ZENGROWTH_REQUIRE_HTTPS=false
ZENGROWTH_SESSION_TTL_SECONDS=28800

# --- Feature flags (disabled features return 503, not 500) ---
FEATURE_PUBLIC_OBSERVABILITY=true
FEATURE_SSE=true

# --- Knowledge graph (SQLite canonical store) ---
KNOWLEDGE_ROOT=data/knowledge
KNOWLEDGE_AUTO_VERIFY_THRESHOLD=0.75
# Chunk embeddings are off by default — nothing reads them yet.
# KNOWLEDGE_EMBEDDINGS_ENABLED=false

# --- Evidence retrieval ---
# The generator loads a broad pool of verified claims, relevance-ranks against the JD,
# then keeps the top N for the prompt + grounding corpus.
# EVIDENCE_CANDIDATE_POOL=200
# EVIDENCE_PROMPT_LIMIT=40
